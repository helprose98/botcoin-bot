# ============================================================
# KRAKEN BTC ACCUMULATION BOT — CONFIGURATION
# ============================================================
# Copy this file to .env and fill in your values.
# Never share your .env file with anyone.
#
# AGGRESSION SCALE used throughout this file:
#   [CONSERVATIVE] — fewer trades, smaller positions, lower risk
#   [BALANCED]     — sensible middle ground for most investors
#   [AGGRESSIVE]   — more trades, larger positions, maximizes accumulation
#                    Best for experienced investors with long time horizons
#                    who can tolerate volatility. DEFAULT IS SET HERE.

# --- Kraken API Credentials ---
KRAKEN_API_KEY=your_api_key_here
KRAKEN_API_SECRET=your_api_secret_here

# --- Trading Pair ---
TRADING_PAIR=XBTUSD

# ============================================================
# ACCUMULATION MODE
# ============================================================
#
#   btc_accumulate — BULL MODE
#     Buy BTC on schedule, deploy USD on dips, recycle profits into more BTC.
#
#   usd_accumulate — BEAR MODE
#     Sell BTC on schedule, deploy BTC on pumps, recycle into more USD.
#
#   auto — CYCLE-AWARE (recommended for experienced investors)
#     Watches 200-day moving average. Switches modes automatically.
#     Bull trend (price 5%+ above 200MA) → btc_accumulate
#     Bear trend (price 5%+ below 200MA) → usd_accumulate
#     Builds history for ~100 days before MA is reliable; defaults to
#     btc_accumulate until then.
#
MODE=auto

# ============================================================
# DCA SETTINGS
# ============================================================
# The single biggest driver of long-term accumulation.
# More capital per week = more BTC stacked over time.
#
#   [CONSERVATIVE] DCA_AMOUNT_USD=25.00
#   [BALANCED]     DCA_AMOUNT_USD=50.00
#   [AGGRESSIVE]   DCA_AMOUNT_USD=100.00  ← recommended for your profile
#
DCA_AMOUNT_USD=100.00

# How often to DCA: daily, weekly, or monthly
DCA_FREQUENCY=weekly

# Day of week for DCA buy/sell (weekly only)
# Monday is historically a slightly lower-price day for BTC
DCA_DAY=monday

# Day of month for monthly DCA (1-28, monthly only)
DCA_DAY_OF_MONTH=1

# Time of day (24hr UTC). 13:00 UTC = 9:00 AM EDT — early US session
# Good liquidity, reasonable spreads
DCA_TIME_UTC=13:00

# ============================================================
# CAPITAL POOL SPLIT
# ============================================================
# What % of your balance to hold as the dip-buying / spike-selling reserve.
# Higher = more firepower for opportunistic trades, less for DCA.
#
#   [CONSERVATIVE] RECYCLER_POOL_PERCENT=0.15
#   [BALANCED]     RECYCLER_POOL_PERCENT=0.20
#   [AGGRESSIVE]   RECYCLER_POOL_PERCENT=0.35  ← more dry powder for dips
#
RECYCLER_POOL_PERCENT=0.35

# ============================================================
# DIP / SPIKE DETECTION — 3 TIERS
# ============================================================
# How far price must move from the 7-day high (dip) or low (spike)
# to trigger a buy or sell. Aggressive settings catch more moves.
#
# Tier 1 — Small move, deploy partial reserve
#   [CONSERVATIVE] 0.12 / deploy 0.40
#   [BALANCED]     0.10 / deploy 0.50
#   [AGGRESSIVE]   0.07 / deploy 0.60  ← catches more dips early
#
DIP_THRESHOLD_PERCENT=0.07
DIP_BUY_DEPLOY_PERCENT=0.60

# Tier 2 — Medium move, deploy most of reserve
#   [CONSERVATIVE] 0.20 / deploy 0.65
#   [BALANCED]     0.20 / deploy 0.75
#   [AGGRESSIVE]   0.15 / deploy 0.80
#
DIP_TIER2_THRESHOLD_PERCENT=0.15
DIP_TIER2_DEPLOY_PERCENT=0.80

# Tier 3 — Major crash/pump, go all in on reserve
#   [CONSERVATIVE] 0.30 / deploy 1.00
#   [BALANCED]     0.30 / deploy 1.00
#   [AGGRESSIVE]   0.22 / deploy 1.00  ← lower bar for "all in"
#
DIP_TIER3_THRESHOLD_PERCENT=0.22
DIP_TIER3_DEPLOY_PERCENT=1.00

# Minimum hours between dip/spike buys (prevents buying every tick in a crash)
# Aggressive setting allows re-triggering sooner across tiers
#   [CONSERVATIVE] 36
#   [BALANCED]     24
#   [AGGRESSIVE]   12
#
DIP_COOLDOWN_HOURS=12

# ============================================================
# RECYCLER SETTINGS
# ============================================================
# Controls when the bot takes partial profits and rebuys cheaper.
# Lower thresholds = fires more often = more opportunities to accumulate
# bonus BTC (or USD) per cycle.
#
# Sell/buy threshold — how far above/below cost basis to trigger
#   [CONSERVATIVE] 0.40  (40% above basis)
#   [BALANCED]     0.25  (25% above basis)
#   [AGGRESSIVE]   0.18  (18% above basis — fires much more frequently)
#
RECYCLER_SELL_THRESHOLD_PERCENT=0.18

# What fraction of holdings to sell/buy per trigger
#   [CONSERVATIVE] 0.08
#   [BALANCED]     0.12
#   [AGGRESSIVE]   0.18  ← larger slice per trade = more impact per cycle
#
RECYCLER_SELL_PERCENT=0.18

# Minimum hours between recycler trades
#   [CONSERVATIVE] 96  (4 days)
#   [BALANCED]     72  (3 days)
#   [AGGRESSIVE]   36  (1.5 days — can fire multiple times in a volatile week)
#
RECYCLER_SELL_COOLDOWN_HOURS=36

# How far price must reverse before rebuying/reselling
#   [CONSERVATIVE] 0.18
#   [BALANCED]     0.12
#   [AGGRESSIVE]   0.08  ← tighter reversal = faster rebuy after selling
#
RECYCLER_REBUY_DROP_PERCENT=0.08

# ============================================================
# AUTO MODE SETTINGS
# ============================================================
# Only applies when MODE=auto
#
# Deviation from 200MA required to confirm a trend change.
# Smaller = more reactive (more switches). Larger = more stable (fewer).
#   [CONSERVATIVE] 0.08
#   [BALANCED]     0.05
#   [AGGRESSIVE]   0.04  ← switches modes slightly sooner
#
AUTO_HYSTERESIS_PERCENT=0.04

# Minimum days in a mode before auto can switch again.
# Prevents thrashing during choppy sideways markets.
#   [CONSERVATIVE] 14
#   [BALANCED]     7
#   [AGGRESSIVE]   5
#
AUTO_MIN_DAYS_IN_MODE=5

# ============================================================
# FEE SETTINGS
# ============================================================
# Kraken maker fee for limit orders.
# Default 0.25% — check your actual tier at Kraken > Account > Fee Schedule
# As your 30-day volume grows, this drops:
#   $0–$50k volume:    0.25% maker / 0.40% taker
#   $50k–$100k:        0.20% / 0.35%
#   $100k–$250k:       0.14% / 0.24%
#   Update this when your tier improves — it affects cost basis calculations.
#
KRAKEN_MAKER_FEE=0.0025

# ============================================================
# SAFETY LIMITS
# ============================================================
MIN_USD_RESERVE=10.00    # Never let USD fall below this
MIN_ORDER_USD=5.00       # Kraken minimum is ~$5
MAX_ORDER_USD=1000.00    # Raised cap for aggressive profile (was $500)

# ============================================================
# PAPER TRADING
# ============================================================
# true  = simulate everything, no real orders (TEST HERE FIRST)
# false = live trading
#
# Run paper mode for at least a few days to confirm the bot
# is behaving as expected before switching to live.
#
PAPER_TRADING=true

# ============================================================
# LOGGING
# ============================================================
LOG_LEVEL=INFO
LOG_FILE=/app/logs/bot.log

# ============================================================
# DASHBOARD PASSWORD
# ============================================================
# Password to access the web dashboard at http://YOUR_IP:8080
# Change this to something only you know.
DASHBOARD_PASSWORD=changeme
